VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Server-side only (Vercel): comma-separated list of origins allowed to hit /api/overpass.
# Leave empty in local dev to allow any origin. In production, set explicitly, e.g.:
# ALLOWED_ORIGINS=https://travelfy.example.com,https://www.travelfy.example.com
ALLOWED_ORIGINS=
